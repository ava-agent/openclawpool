# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Service
ARK_API_KEY=your-ark-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_CHAT_MODEL=doubao-seed-2-0-code-preview-260215
# Optional. Defaults to 30000.
# ARK_API_TIMEOUT_MS=30000

# CORS Configuration (comma-separated list)
# Defaults: http://localhost:3000, https://pool.rxcloud.group
ALLOWED_ORIGINS=http://localhost:3000,https://pool.rxcloud.group

# Rate Limiting (optional)
# Default values are set in code, but can be overridden
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
